# ============================================================
# SignalFlow — Environment Variables (template)
# ------------------------------------------------------------
# 1. Copy this file to ".env"      ->   cp .env.example .env
# 2. Fill in the real values below.
# 3. NEVER commit your .env file (it is git-ignored).
# ============================================================

# ----- Database: Supabase PostgreSQL -----
# DATABASE_URL  = the POOLED connection (used by the running app). Port 6543.
# DIRECT_URL    = the DIRECT connection (used by Prisma migrations). Port 5432.
# Get both from: Supabase Dashboard -> Project Settings -> Database -> Connection string
DATABASE_URL="postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# ----- Authentication: Clerk -----
# Get these from: Clerk Dashboard -> your app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"

# Where Clerk's hosted forms live, and where to send users after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ----- Apollo (enrichment + contacts + re-engagement) -----
# Get it from: Apollo -> Settings -> Integrations -> API -> API Keys
APOLLO_API_KEY=""

# ----- Daily scan cron secret (Intent engine) -----
# Any long random string. Used to authorize POST /api/cron/scan.
CRON_SECRET=""

# ----- Google Sheets -----
# No env var needed: upload the service-account JSON in Settings → Google Sheets.

# ----- Phase 3: AI -----
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
